PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/mern_todos

# Optional fallback JWT secret for local/non-Supabase mode.
JWT_SECRET=todo-secret
JWT_EXPIRES_IN=7d

# Supabase Auth verification (recommended in production).
# Example:
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_JWT_AUD=authenticated
SUPABASE_URL=
SUPABASE_JWT_AUD=authenticated
